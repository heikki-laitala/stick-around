{
  "name": "stick-around",
  "description": "A tiny stick-man RPG to play on top of your terminal while Claude Code works",
  "version": "1.0.0",
  "author": {
    "name": "Heikki Laitala"
  },
  "homepage": "https://github.com/heikki-laitala/stick-around",
  "repository": "https://github.com/heikki-laitala/stick-around",
  "license": "MIT",
  "keywords": ["rpg", "game", "overlay", "stick-figure", "terminal", "fun"],
  "icon": "src-tauri/icons/icon.png",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap.cjs\" || true"
          }
        ]
      }
    ]
  }
}
